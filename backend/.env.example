# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=shopping_agent

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported values: openai | gemini | ollama | anthropic
LLM_PROVIDER=openai
# Optional: override the default model for the chosen provider
# LLM_MODEL=gpt-4o-mini

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=AIza...
# LLM_MODEL=gemini-1.5-flash

# Ollama — local, no key needed (used when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# Anthropic (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-haiku-20240307

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# eBay API
EBAY_APP_ID=your-ebay-app-id
EBAY_BASE_URL=https://svcs.ebay.com/services/search/FindingService/v1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# Cache
CACHE_TTL_SECONDS=3600

# App
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
