# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=shopping_agent

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: openai | gemini | ollama | anthropic
LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini   # optional override

# OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
# GEMINI_API_KEY=AIza...
# LLM_MODEL=gemini-1.5-flash

# Ollama — local, no key needed
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-haiku-20240307

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id

# ── eBay API ──────────────────────────────────────────────────────────────────
EBAY_APP_ID=your-ebay-app-id
EBAY_BASE_URL=https://svcs.ebay.com/services/search/FindingService/v1

# ── Razorpay (TEST MODE ONLY — no real money) ─────────────────────────────────
# Get test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-secret
# Webhook secret is configured separately in the Razorpay Dashboard under
# Settings → Webhooks, when you register the webhook URL
# (e.g. https://yourdomain.com/api/v1/checkout/webhook) for the
# payment.captured event. This is NOT the same value as RAZORPAY_KEY_SECRET.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Leave both empty to use mock payment flow in dev

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=2.0.0
DEBUG=true
