# Git ignore rules
# ------------------------------
# Python
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# ------------------------------
# Virtual Environments
# ------------------------------
venv/
.env/
.venv/
env/
ENV/

# ------------------------------
# Environment Variables
# ------------------------------
.env
.env.*
!.env.example

# ------------------------------
# Distribution / Packaging
# ------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------
# Logs
# ------------------------------
*.log
logs/
*.out
*.err

# ------------------------------
# Testing
# ------------------------------
.pytest_cache/
.coverage
htmlcov/

# ------------------------------
# IDE / Editor
# ------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ------------------------------
# Mypy / Type Checking
# ------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------
# PyCharm / JetBrains
# ------------------------------
*.iml

# ------------------------------
# Docker
# ------------------------------
docker-compose.override.yml

# ------------------------------
# Cache / Temp
# ------------------------------
*.cache
.cache/
tmp/
temp/

# ------------------------------
# Database (if local)
# ------------------------------
*.sqlite3
*.db

# ------------------------------
# Coverage Reports
# ------------------------------
coverage.xml

# ------------------------------
# Misc
# ------------------------------
*.bak
*.backup
*.old